//Elanlarim/page.tsx
"use client";

import React from 'react';
import Link from 'next/link';
import { 
  PlusCircle, 
  Youtube, 
  Instagram, 
  Globe, 
  MessageSquare,
  ShieldCheck,
  LayoutGrid,
  ArrowRight
} from 'lucide-react';

export default function ElanlarimPage() {
  return (
    <div className="min-h-screen bg-gray-50 pb-20">
      <div className="bg-white border-b">
        <div className="container mx-auto px-4 py-4 flex items-center gap-2 text-sm text-gray-500">
          <Link href="/" className="hover:text-blue-600">Home</Link>
          <ArrowRight size={14} />
          <span className="font-semibold text-gray-900">Listings</span>
        </div>
      </div>

      <div className="container mx-auto px-4 mt-8">
        <div className="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
          <div>
            <h1 className="text-3xl font-bold text-gray-900">Elanlarımı İdarə Et</h1>
            <p className="text-gray-500 mt-1">Aşağıdakı düymələrdən istifadə edərək yeni satış siyahısı yarada bilərsiniz.</p>
          </div>
        </div>

        <div className="bg-white p-6 rounded-2xl border border-dashed border-blue-300 mb-12">
          <div className="flex items-center gap-2 mb-6">
            <PlusCircle className="text-blue-600" size={24} />
            <h2 className="text-xl font-bold italic">Yeni Siyahı Əlavə Et <span className="text-green-500 text-sm font-normal not-italic ml-2">(Pulsuz)</span></h2>
          </div>
          
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <button className="flex items-center justify-center gap-3 p-4 bg-red-50 text-red-700 rounded-xl border border-red-100 hover:bg-red-100 transition font-bold">
              <Youtube size={20} /> YouTube Kanalı
            </button>
            
            <button className="flex items-center justify-center gap-3 p-4 bg-purple-50 text-purple-700 rounded-xl border border-purple-100 hover:bg-purple-100 transition font-bold">
              <Instagram size={20} /> Instagram Hesabı
            </button>

            <button className="flex items-center justify-center gap-3 p-4 bg-gray-900 text-white rounded-xl hover:bg-black transition font-bold">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.17-2.89-.6-4.13-1.47V18.77a6.738 6.738 0 01-1.12 3.65c-1.3 1.95-3.64 3.03-5.96 2.87-2.2-.14-4.32-1.43-5.4-3.37-1.16-2.12-1-4.87.41-6.84 1.34-1.84 3.73-2.69 5.92-2.13V17c-1.07-.31-2.35-.03-3.13.78-.85.93-.84 2.44.02 3.37.86.92 2.37.95 3.26.06.33-.33.58-.75.69-1.21.05-1.57.03-3.14.03-4.71V0z"/></svg>
              TikTok Hesabı
            </button>

            <button className="flex items-center justify-center gap-3 p-4 bg-blue-50 text-blue-700 rounded-xl border border-blue-100 hover:bg-blue-100 transition font-bold">
              <Globe size={20} /> Vebsayt / Domain
            </button>
          </div>
        </div>

        <div className="bg-white rounded-3xl p-12 text-center border shadow-sm">
          <div className="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-400">
            <LayoutGrid size={40} />
          </div>
          <h3 className="text-xl font-bold mb-2">Hələ elanınız yoxdur</h3>
          <p className="text-gray-500 mb-6">Satmaq istədiyiniz hesabı yuxarıdakı kateqoriyalardan birini seçərək əlavə edin.</p>
        </div>

        <div className="grid grid-cols-2 md:grid-cols-4 gap-8 mt-20 pt-10 border-t text-sm">
          <div>
            <h4 className="font-bold mb-4 text-gray-900">Sosial Media</h4>
            <ul className="space-y-2 text-gray-500">
              <li className="hover:text-blue-600 cursor-pointer">Səhifə Al</li>
              <li className="hover:text-blue-600 cursor-pointer">YouTube Kanalları</li>
              <li className="hover:text-blue-600 cursor-pointer">TikTok Hesabları</li>
              <li className="hover:text-blue-600 cursor-pointer">Twitter (X) Hesabları</li>
            </ul>
          </div>
          <div>
            <h4 className="font-bold mb-4 text-gray-900">Xidmətlərimiz</h4>
            <ul className="space-y-2 text-gray-500">
              <li className="hover:text-blue-600 cursor-pointer flex items-center gap-1"><ShieldCheck size={14}/> Escrow Service</li>
              <li className="hover:text-blue-600 cursor-pointer">Son Satılanlar</li>
              <li className="hover:text-blue-600 cursor-pointer">Affiliate Program</li>
            </ul>
          </div>
          <div>
            <h4 className="font-bold mb-4 text-gray-900">ACCOUNTmarket</h4>
            <ul className="space-y-2 text-gray-500">
              <li className="hover:text-blue-600 cursor-pointer">Haqqımızda</li>
              <li className="hover:text-blue-600 cursor-pointer">Əlaqə</li>
              <li className="hover:text-blue-600 cursor-pointer flex items-center gap-1"><MessageSquare size={14}/> Bloq</li>
            </ul>
          </div>
          <div>
            <h4 className="font-bold mb-4 text-gray-900">Alətlər</h4>
            <ul className="space-y-2 text-gray-500">
              <li className="hover:text-blue-600 cursor-pointer">Fake Follower Check</li>
              <li className="hover:text-blue-600 cursor-pointer">YouTube Automation</li>
              <li className="hover:text-blue-600 cursor-pointer">TikTok ID Find</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  );
}

