//Elani_yerlesidr/page.tsx
import React from 'react';
import { 
    CheckCircle, 
    ShieldCheck, 
    MessageSquare, 
    BarChart3 ,
    BadgeDollarSign,
    LayoutGrid
} from 'lucide-react'; 
import Link from 'next/link';


export default function ElanYerlesdir() {
    return (
        <div className="max-w-6xl mx-auto px-4 py-12 font-sans">
    
        {/* --- NAVBAR BURADAN BAŞLAYIR --- */}
            <header className="bg-white border-b sticky top-0 z-50">
                <div className="container mx-auto px-4 h-16 flex items-center justify-between">
                    <Link href="/">
                        <h1 className="text-2xl font-bold text-blue-600 cursor-pointer">
                            <span className="underline decoration-blue-600">ACCOUNT</span>
                            <span className="overline decoration-blue-600">market</span>
                        </h1>
                    </Link>

                    <nav className="hidden lg:flex items-center space-x-6 font-medium text-gray-600">
                        <Link href="/" className="hover:text-blue-600 transition">Almaq</Link>
                        <div className="h-6 w-[1px] bg-gray-200"></div>
                        <Link href="/Escrow" className="flex items-center gap-1 hover:text-blue-600">
                            <ShieldCheck size={18} /> Escrow
                        </Link>
                        <a href="#" className="flex items-center gap-1 hover:text-blue-600">
                            <BadgeDollarSign size={18} /> Offer
                        </a>
                        <Link href="/Elanlarim" className="flex items-center gap-1 hover:text-blue-600 transition">
                            <LayoutGrid size={18} /> Elanlarım
                        </Link>
                    </nav>

                    <div className="flex items-center space-x-4">
                        <div className="hidden sm:flex flex-col items-end mr-2">
                            <span className="text-[10px] text-gray-400 uppercase font-bold tracking-wider">Balans</span>
                            <span className="text-sm font-bold text-green-600">125.50 AZN</span>
                        </div>
                        {/* Kabinetim Dropdown hissəsini bura əlavə edə bilərsən */}
                        <div className="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold">AA</div>
                    </div>
                </div>
            </header>
            {/* --- NAVBAR BURADA BİTİR --- */}
        <div className="bg-blue-50 border border-blue-100 rounded-lg p-4 mb-10 text-center">
        <p className="text-blue-800 text-sm sm:text-base">
          🚀 Yeni Özəlliklər! Bizə yeni funksiyalar qurmağa və **ACCOUNTmarket**-i inkişaf etdirməyə kömək edin. 
            <a href="#" className="font-bold underline ml-1 hover:text-blue-600 transition">Səs vermək üçün buraya klikləyin!</a>
        </p>
        </div>

    <div className="text-center mb-16">
        <h1 className="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">
          TikTok Hesablarını və Youtube Kanallarını **ACCOUNTmarket**-də Satın
        </h1>
        <p className="text-gray-600 max-w-3xl mx-auto leading-relaxed">
          **ACCOUNTmarket**-də satış etmək məhdud zaman üçün **pulsuzdur**. Sadəcə pulsuz qeydiyyatdan keçin, Elanlar səhifəsinə daxil olun və mülkiyyətinizi satışa çıxarın. 
          **ACCOUNTmarket** həmçinin mülkiyyətinizi təhlükəsiz şəkildə ötürməyə imkan verən hərtərəfli **depozit (escrow)** xidməti təklif edir.
        </p>
    </div>


        <Link href={"/Elanlarim"}>
        <button className="hidden sm:block bg-blue-600 text-white px-5 py-2.5 rounded-xl text-sm font-bold
            hover:bg-blue-700 transition shadow-md shadow-blue-100">
            + Yeni elan yerləşdir
        </button>
        </Link>
    <div className="grid md:grid-cols-2 gap-8 mb-20">
        <div className="p-8 border border-gray-100 rounded-2xl shadow-sm hover:shadow-md transition bg-white">
        <h2 className="text-2xl font-bold mb-4 text-gray-800">TikTok Hesablarını Satın</h2>
        <p className="text-gray-600">
            **ACCOUNTmarket** dünyanın hər yerindən media şirkətlərini, iri brendləri, influenserləri və marketinq agentliklərini cəlb edən ən böyük tematik səhifə bazarıdır.
        </p>
        </div>
        <div className="p-8 border border-gray-100 rounded-2xl shadow-sm hover:shadow-md transition bg-white">
        <h2 className="text-2xl font-bold mb-4 text-gray-800">YouTube Kanallarını Satın</h2>
        <p className="text-gray-600">
            YouTube yaradıcıları və media şirkətləri bəzi ən böyük YouTube kanallarını və hesablarını dəyişdirmək üçün **ACCOUNTmarket**-dən istifadə edirlər.
        </p>
        </div>
    </div>

    <div className="grid md:grid-cols-2 gap-12 items-center border-t pt-16">
        <div>
        <h3 className="text-2xl font-bold mb-4 flex items-center gap-2">
            <MessageSquare className="text-blue-600" /> Təklifləri və Mesajları İdarə Edin
        </h3>
        <p className="text-gray-600 mb-4">
            Maraqlanan alıcılardan gələn təklifləri və mesajları tək bir yerdən idarə edin. Hesabınız üçün təklifləri qəbul etdikdən sonra depozit (escrow) prosesini başlatmaq və satışı yekunlaşdırmaq imkanınız olacaq.
        </p>
        </div>
        <div>
        <h3 className="text-2xl font-bold mb-4 flex items-center gap-2">
            <ShieldCheck className="text-blue-600" /> **ACCOUNTmarket** Escrow (Depozit)
        </h3>
        <p className="text-gray-600">
            **ACCOUNTmarket** satıcılara hesabları təhlükəsiz şəkildə satmağa və ödənişləri geri qaytarılma (chargeback) riski olmadan almağa imkan verən hərtərəfli depozit xidməti təklif edir.
        </p>
        </div>
    </div>

    <div className="grid grid-cols-2 md:grid-cols-4 gap-8 mt-24 border-t pt-12 text-sm">
        <div>
    <h4 className="font-bold mb-4 text-gray-900">Sosial Media</h4>
    <ul className="space-y-2 text-gray-500">
            <li className="hover:text-blue-600 cursor-pointer">Tematik Səhifə Al</li>
            <li className="hover:text-blue-600 cursor-pointer">YouTube Kanalı Al</li>
            <li className="hover:text-blue-600 cursor-pointer">TikTok Hesabı Al</li>
    </ul>
        </div>
        <div>
        <h4 className="font-bold mb-4 text-gray-900">Xidmətlərimiz</h4>
        <ul className="space-y-2 text-gray-500">
            <li className="hover:text-blue-600 cursor-pointer">Escrow Xidməti</li>
            <li className="hover:text-blue-600 cursor-pointer">Son Satılanlar</li>
            <li className="hover:text-blue-600 cursor-pointer">Affiliate Proqramı</li>
        </ul>
        </div>
        <div>
            <h4 className="font-bold mb-4 text-gray-900">Bizim Haqqımızda</h4>
            <ul className="space-y-2 text-gray-500">
            <li className="hover:text-blue-600 cursor-pointer">Əlaqə</li>
            <li className="hover:text-blue-600 cursor-pointer">**ACCOUNTmarket** Bloq</li>
            <li className="hover:text-blue-600 cursor-pointer">Tərəfdaş Həlləri</li>
            </ul>
        </div>
        <div>
            <h4 className="font-bold mb-4 text-gray-900">Alətlər</h4>
            <ul className="space-y-2 text-gray-500">
            <li className="hover:text-blue-600 cursor-pointer">Saxta İzləyici Yoxla</li>
            <li className="hover:text-blue-600 cursor-pointer">YouTube Avtomatlaşdırma</li>
            <li className="hover:text-blue-600 cursor-pointer">ID Tapıcılar</li>
            </ul>
        </div>
        </div>

    </div>
    );
}


